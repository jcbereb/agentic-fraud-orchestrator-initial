      <bpmn:intermediateCatchEvent id="Event_0kdpp3l" name="Información adicional recepcionada" zeebe:modelerTemplate="io.camunda.connectors.webhook.WebhookConnectorIntermediate.v1" zeebe:modelerTemplateVersion="11" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
